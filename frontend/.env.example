# WebSocket connection URL for collaboration backend (HTTP/HTTPS base for SockJS)
# Local: http://localhost:8080
# Production: https://your-backend-app.onrender.com
VITE_WS_BASE=http://localhost:8080

# HTTP execution base URL
# Local: http://localhost:8080
# Production: https://your-backend-app.onrender.com
VITE_EXECUTION_HTTP=http://localhost:8080

# WebSocket base URL for real-time execution output
# Local: ws://localhost:3001
# Production: wss://your-execution-service.onrender.com
VITE_EXECUTION_WS=ws://localhost:3001
