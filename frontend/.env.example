# WebSocket connection URL for collaboration backend (HTTP/HTTPS base for SockJS)
# Local: http://localhost:8080
# Production: https://your-backend-app.onrender.com
VITE_WS_BASE=http://localhost:8080

# HTTP execution endpoint for running code
# Local: http://localhost:8080/execute
# Production: https://your-backend-app.onrender.com/execute
VITE_EXECUTION_HTTP=http://localhost:8080/execute

# WebSocket endpoint for real-time execution output
# Local: ws://localhost:3001/ws
# Production: wss://your-execution-service.onrender.com/ws
VITE_EXECUTION_WS=ws://localhost:3001/ws
